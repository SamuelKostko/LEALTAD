# Server
PORT=3000
HOST=0.0.0.0

# Public base URL used in activation emails (optional).
# Example: https://wallet.tudominio.com
PUBLIC_ORIGIN=

# Optional: brand name shown in activation email header
# Example: TAM Cargo Rewards
EMAIL_BRAND_NAME= NEXUS REWARDS

# Optional: accent color for activation email (button + underline)
# Example: #2563eb
EMAIL_ACCENT_COLOR=

# Protect admin endpoints (choose a strong random string)
ADMIN_KEY=change-me

# Protect POS webhook (choose a strong random string)
WEBHOOK_SECRET=change-me

# Database provider
# - local: uses data/cards.json (default)
# - firebase: uses Firebase Firestore
DB_PROVIDER=local

# Firebase Admin SDK (Firestore)
# Create a Firebase project -> enable Firestore -> generate a Service Account key JSON.
# Put the JSON file somewhere safe (DO NOT COMMIT IT) and point to it here.
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-service-account.json
# Optional: override Firestore project (usually embedded in the JSON key)
FIREBASE_PROJECT_ID=

# SMTP (required for automatic activation emails)
# Gmail SMTP
# - SSL: 465 (recommended)
# - STARTTLS: 587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password_here
# Note: with Gmail, the From address should generally match SMTP_USER
SMTP_FROM="Nexus Rewards <your@gmail.com>"
