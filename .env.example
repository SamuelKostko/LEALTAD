# This project is intended to run on Vercel (serverless).
# Local PORT/HOST are not required unless you run a custom dev server.


# Public base URL used in activation emails (optional).
# Example: https://wallet.tudominio.com
PUBLIC_ORIGIN=

# Optional: brand name shown in activation email header
# Example: TAM Cargo Rewards
EMAIL_BRAND_NAME= NEXUS REWARDS

# Optional: accent color for activation email (button + underline)
# Example: #2563eb
EMAIL_ACCENT_COLOR=

# Admin login (simple)
# Use a strong password and a random SESSION_SECRET.
ADMIN_PASSWORD=change-me
SESSION_SECRET=change-me-very-long-random

# Backwards compatible: if you still set ADMIN_KEY, it's accepted as the admin password.
ADMIN_KEY=30547862

# Protect POS webhook (choose a strong random string)
WEBHOOK_SECRET=change-me

# QR signing secret (required for QR de cobro)
# Used to sign/verify the POS redeem URL payload.
QR_SECRET=change-me-very-long-random

# Database
# Firestore only (no local JSON)

# Firebase Admin SDK (Firestore)
# Create a Firebase project -> enable Firestore -> generate a Service Account key JSON.
# Put the JSON file somewhere safe (DO NOT COMMIT IT).
# On Vercel, prefer setting the whole JSON in an env var:
FIREBASE_SERVICE_ACCOUNT_JSON=

# Optional: for local dev only
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-service-account.json
# Optional: override Firestore project (usually embedded in the JSON key)
FIREBASE_PROJECT_ID=

# SMTP (required for automatic activation emails)
# Gmail SMTP
# - SSL: 465 (recommended)
# - STARTTLS: 587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password_here

# Option A (simple): full From header
# Note: many providers require the From domain/address to be authorized.
SMTP_FROM="Nexus Rewards <your@gmail.com>"

# Option B (structured): name + email separately
# SMTP_FROM_NAME="Nexus Rewards"
# SMTP_FROM_EMAIL=noreply@tudominio.com

# IMPORTANT: To send FROM @tudominio.com you typically need SPF/DKIM configured
# and an SMTP provider/account for that domain (Workspace/Zoho/Mailgun/SendGrid/etc).
